# AWS Configuration (from CloudFormation deploy)
NEXT_PUBLIC_AWS_REGION=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

# Anthropic API Key (server-only, NOT exposed to client)
ANTHROPIC_API_KEY=

# Anonymous mode — accept X-Device-Id (UUID) instead of Cognito JWT.
# Set to "1" for pilot / demo / no-Cognito deploys. Unset or "0" in prod
# once Cognito is wired up. NOT SECURE — anyone with the deviceId can
# read/write that user's DB row.
ALLOW_ANONYMOUS_USERS=

# DynamoDB persistence (server-only). AWS_REGION must be set.
# In Amplify the IAM role is auto-detected; locally use AWS CLI creds.
# See docs/dynamodb-setup.md for table creation + IAM policy.
AWS_REGION=us-east-1

# Optional: table-name prefix so staging and prod can share an account.
# When set, table names become e.g. rs_prod_user_plans. Leave empty for default.
DYNAMODB_TABLE_PREFIX=

# Local-dev only — credentials. In Amplify the SSR Lambda gets these from
# the attached IAM role automatically and these are unnecessary.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=  # alternative: name of profile in ~/.aws/credentials

# Resend (optional — enables weekly plan health check emails)
# Sign up at resend.com, verify your sending domain
RESEND_API_KEY=

# Cron secret — set in GitHub Actions secrets as CRON_SECRET
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional: per-invocation cost cap. Each user triggers up to 8 Haiku calls,
# so 50 users ≈ $1.20 per Monday. Default 50, hard ceiling 200.
WEEKLY_CHECK_BATCH_SIZE=50

# Emergency kill switch — set to "1" to no-op the weekly cron without
# touching the GitHub Actions workflow.
WEEKLY_CHECK_DISABLED=

# --- Plaid account aggregation (optional) ---
# Get credentials at https://dashboard.plaid.com. Until set, the Accounts tab
# uses the built-in demo institution picker.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | production
