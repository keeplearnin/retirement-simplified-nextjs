# AWS Configuration (from CloudFormation deploy)
NEXT_PUBLIC_AWS_REGION=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=

# Anthropic API Key (server-only, NOT exposed to client)
ANTHROPIC_API_KEY=

# Supabase (server-only — service role key, never expose to client)
# Create project at supabase.com, run supabase/migrations/001_plan_snapshots.sql
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Resend (optional — enables weekly plan health check emails)
# Sign up at resend.com, verify your sending domain
RESEND_API_KEY=

# Cron secret — set in GitHub Actions secrets as CRON_SECRET
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional: per-invocation cost cap. Each user triggers up to 8 Haiku calls,
# so 50 users ≈ $1.20 per Monday. Default 50, hard ceiling 200.
WEEKLY_CHECK_BATCH_SIZE=50

# Emergency kill switch — set to "1" to no-op the weekly cron without
# touching the GitHub Actions workflow.
WEEKLY_CHECK_DISABLED=
